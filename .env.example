# Qwen / DashScope
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_TURBO=qwen-turbo
QWEN_MODEL_PLUS=qwen-plus
QWEN_EMBED_MODEL=text-embedding-v3
QWEN_EMBED_DIM=1024

# Postgres / Supabase
DATABASE_URL=postgresql://healthdesk:healthdesk@postgres:5432/healthdesk
SUPABASE_URL=
SUPABASE_KEY=

# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# STT / TTS
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# WhatsApp / Evolution API
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
EVOLUTION_AUTH_MODE=hmac
EVOLUTION_WEBHOOK_SECRET=
# JSON array of CIDR ranges; only used when EVOLUTION_AUTH_MODE=token
EVOLUTION_IP_ALLOWLIST=[]
EVOLUTION_SEND_TIMEOUT=8.0

# n8n + escalation
N8N_WEBHOOK_URL=
GATEWAY_PROXY_KEY=change-me-internal-cron-key
STAFF_ESCALATION_WEBHOOK_URL=

# Feature flags
HEALTHDESK_VOICE=true
# Set to "demo" to enable the demo patient phone fallback for browser voice.
# Keep "production" (default) for real deployments — prevents all browser
# sessions from sharing a single patient's memory.
HEALTHDESK_ENV=demo
# Fallback phone used to identify the caller for browser-based voice
# demos when LiveKit gives us no caller metadata. Must match a seeded
# patient in `evals/seed_demo.py` so recall surfaces real memories.
HEALTHDESK_DEMO_PATIENT_PHONE=2340000000000

# Web chat
# If set, all /webhooks/web requests must include X-API-Key: <value>.
# Leave empty to disable auth (dev/local only).
WEB_API_KEY=

# Clinic timezone (IANA zone name, e.g. "Africa/Lagos", "America/New_York")
CLINIC_TIMEZONE=UTC

# Escalation confidence threshold — intents below this score auto-escalate to staff
ESCALATION_CONFIDENCE_THRESHOLD=0.45
