# Qwen Cloud (DashScope international endpoint).
# Generate a key at https://www.qwencloud.com → API Keys, workspace-scoped.
# Docs: https://docs.qwencloud.com/developer-guides/getting-started/introduction
DASHSCOPE_API_KEY=
QWEN_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_TURBO=qwen3.6-flash
QWEN_MODEL_PLUS=qwen3.7-plus
QWEN_EMBED_MODEL=text-embedding-v4
QWEN_EMBED_DIM=1024

# Postgres / Supabase
DATABASE_URL=postgresql://healthdesk:healthdesk@postgres:5432/healthdesk
SUPABASE_URL=
SUPABASE_KEY=

# Twilio (voice telephony — Media Streams over WebSocket)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# STT / TTS
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
# ElevenLabs voice id. Defaults to the stock "Rachel" voice if unset.
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# WhatsApp / Evolution API
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
EVOLUTION_AUTH_MODE=hmac
EVOLUTION_WEBHOOK_SECRET=
# JSON array of CIDR ranges; only used when EVOLUTION_AUTH_MODE=token
EVOLUTION_IP_ALLOWLIST=[]
EVOLUTION_SEND_TIMEOUT=8.0

# n8n + escalation
N8N_WEBHOOK_URL=
# Shared secret between the gateway and n8n cron jobs hitting internal
# endpoints. REQUIRED for any non-local deployment.
GATEWAY_PROXY_KEY=
STAFF_ESCALATION_WEBHOOK_URL=
# Guards the /staff human-in-the-loop dashboard. Empty = open (local demo only).
# REQUIRED for any non-local deployment — without it the entire HITL queue is
# unauthenticated.
STAFF_DASHBOARD_KEY=

# Feature flags
HEALTHDESK_VOICE=true
# Set to "demo" to enable the demo patient phone fallback for browser voice.
# Keep "production" for real deployments — prevents all browser sessions from
# sharing a single patient's memory.
HEALTHDESK_ENV=production
# Fallback phone used to identify the caller for browser-based voice
# demos when LiveKit gives us no caller metadata. Must match a seeded
# patient in `evals/seed_demo.py` so recall surfaces real memories.
# Placeholder by default — only used when HEALTHDESK_ENV=demo.
HEALTHDESK_DEMO_PATIENT_PHONE=2340000000000

# Web chat
# If set, all /webhooks/web requests must include X-API-Key: <value>.
# Leave empty to disable auth (dev/local only).
WEB_API_KEY=

# Email channel (optional). Inbound via a provider parse webhook to
# /webhooks/email; outbound via the provider send API (Postmark-shaped).
EMAIL_API_URL=https://api.postmarkapp.com
EMAIL_API_TOKEN=
EMAIL_FROM=
# If set, inbound /webhooks/email requests must include X-Webhook-Secret: <value>.
EMAIL_WEBHOOK_SECRET=
EMAIL_SEND_TIMEOUT=8.0

# Clinic timezone (IANA zone name, e.g. "Africa/Lagos", "America/New_York")
CLINIC_TIMEZONE=UTC

# Clinic business hours — drive real appointment-slot generation.
CLINIC_OPEN_HOUR=9
CLINIC_CLOSE_HOUR=17
CLINIC_SLOT_MINUTES=30
# ISO weekday numbers the clinic is open (1=Mon .. 7=Sun), JSON array.
CLINIC_WORKING_DAYS=[1,2,3,4,5]
SLOT_SEARCH_DAYS=14

# Answering policy: "always" (handle 24/7) or "after_hours" (auto-handle only
# when closed; during open hours acknowledge and hand off to staff).
ANSWER_MODE=always

# Google Calendar (optional). Set BOTH to enable real free/busy + appointment
# mirroring; leave empty to use the local Postgres-only scheduler.
GOOGLE_CALENDAR_ID=
# Path to a service-account JSON key, or the JSON contents inline.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Escalation confidence threshold — intents below this score auto-escalate to staff
ESCALATION_CONFIDENCE_THRESHOLD=0.45
